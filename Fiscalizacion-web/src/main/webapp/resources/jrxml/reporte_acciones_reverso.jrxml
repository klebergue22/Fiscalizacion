	<parameter name="ACCION" class="java.lang.String"/>
	<queryString language="SQL">
		<![CDATA[SELECT 	F.NOMBRE_C PERSONA_REEMPLAZA, 
	A.NOMBRE_C,
	A.NO_CEDULA CEDULA_POSESIONADO,
	B.NO_CAUCION, 
	B.FECHA_CAUCION, 
	B.OBS_CAUCION, 
	B.PUESTO_REEMPLAZA, 
	B.OBS_REEMPLAZA, 
	B.NO_ACCION_REEMPLAZA, 
	B.FECHA_ACCION_REEMPLAZA, 
	B.COLEGIO_PROFESIONALES, 
	B.NO_AFILIACION_COLEGIO, 
	B.FECHA_AFILIACION, 
	B.LUGAR_POSESION, 
	B.FECHA_POSESION,
	C.PIE_FIRMA JEFE_PERSONAL
FROM 	RH.T_ACCION_PERSONAL B, 
	RH.T_DAT_EMPLEADO A, 
	RH.T_DAT_EMPLEADO C, 
	RH.T_DAT_EMPLEADO D, 
	RH.T_DAT_EMPLEADO E, 
	RH.T_DAT_EMPLEADO F
WHERE 	A.NO_PERSONA (+) = B.NO_PERSONA AND
	C.NO_PERSONA (+) = B.NO_JEFE_PERSONA AND
	E.NO_PERSONA (+) = B.NO_DIRECTOR AND
	D.NO_PERSONA (+) = B.NO_PERSONA_REGISTRO AND
	F.NO_PERSONA (+) = B.NO_PERSONA_REEMPLAZA AND
	B.NO_ACCION = $P{ACCION}

]]>
	</queryString>
