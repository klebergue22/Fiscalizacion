	<queryString language="SQL">
		<![CDATA[SELECT A.CODIGO COD,
                T_DAT_EMPLEADO.NOMBRE_C,
                A.FECHA,
                A.HORA,
                A.MINUTO,
                T_AREAS.DESCRIP
  FROM RELOJ A, T_DAT_EMPLEADO, T_AREAS, T_CONTRATACIONES
 WHERE 
   TO_CHAR(A.FECHA, 'yyyy/mm/dd') BETWEEN $P{FechaDesde} AND $P{FechaHasta}
   AND A.CODIGO = T_DAT_EMPLEADO.CODIGO
   AND T_CONTRATACIONES.NO_PERSONA = T_DAT_EMPLEADO.NO_PERSONA
   AND T_CONTRATACIONES.NO_CD = T_AREAS.NO_CD
   AND T_CONTRATACIONES.ESTADO = 'V'
   AND (A.CODIGO = $P{CODIGO} OR A.CODIGO = $P{CODIGO1} OR A.CODIGO = $P{CODIGO2} OR A.CODIGO = $P{CODIGO3} OR A.CODIGO = $P{CODIGO4} OR A.CODIGO = $P{CODIGO5} 
   	OR A.CODIGO = $P{CODIGO6} OR A.CODIGO = $P{CODIGO7} OR A.CODIGO = $P{CODIGO8} OR A.CODIGO = $P{CODIGO9} OR A.CODIGO = $P{CODIGO10}
   	OR A.CODIGO = $P{CODIGO11} OR A.CODIGO = $P{CODIGO12} OR A.CODIGO = $P{CODIGO13})
 ORDER BY T_DAT_EMPLEADO.NOMBRE_C, A.FECHA, A.HORA, A.MINUTO]]>
	</queryString>
