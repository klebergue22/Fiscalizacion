	<parameter name="pathImagen" class="java.lang.String"/>
	<parameter name="FechaDesde" class="java.lang.String"/>
	<queryString language="SQL">
		<![CDATA[SELECT E.NO_PERSONA, E.NOMBRE_C, TO_NUMBER(E.CODIGO) AS CODIGO 
FROM T_DAT_EMPLEADO E, T_CONTRATACIONES C
WHERE E.NO_PERSONA = C.NO_PERSONA
AND C.ESTADO = 'V' AND (C.C_CONTRATO <> 28 AND C.C_CONTRATO <> 32 AND C.C_CONTRATO <> 6)
AND TO_DATE($P{FechaDesde}, 'DD/MM/YYYY') >= TRUNC (C.F_CONTRATO )
AND TO_NUMBER (E.CODIGO) NOT IN ( SELECT codigo from reloj
where (TRUNC (fecha) BETWEEN  TO_DATE($P{FechaDesde}, 'DD/MM/YYYY') 
AND TO_DATE($P{FechaDesde}, 'DD/MM/YYYY'))
group by codigo )
order by E.NOMBRE_C]]>
	</queryString>
	<field name="NO_PERSONA" class="java.math.BigDecimal">
