	<property name="com.jaspersoft.studio.property.dataset.dialog.DatasetDialog.sash.w1" value="781"/>
	<property name="com.jaspersoft.studio.property.dataset.dialog.DatasetDialog.sash.w2" value="207"/>
	<property name="com.jaspersoft.studio.unit." value="pixel"/>
	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="RHIGM"/>
	<parameter name="ACCION" class="java.lang.String"/>
	<parameter name="fondo1" class="java.lang.String">
		<defaultValueExpression><![CDATA["D:/PROYECTO FISC/IMAGENES/accionf.JPEG"]]></defaultValueExpression>
	</parameter>
	<queryString language="SQL">
		<![CDATA[SELECT A.PRI_APELLIDO || ' ' || A.SEG_APELLIDO APELLIDOS,
       A.NO_CEDULA,
       A.SEGURO_SOCIAL,
       A.NOMBRES NOMBRES,
       C.PIE_FIRMA JEFE_PERSONAL,
       E.PIE_FIRMA DIRECTOR,      
       B.NO_ACCION,
       B.FECHA,
    --   B.NO_DECRETO,
    --   B.NO_ACUERDO,
       B.FECHA_RESOLUCION,
       B.FECHA_RIGE,
       B.EXPLICACION,
       DECODE(NVL(B.L_INGRESO, 0), 1, 'X', '') INGRESO,
       DECODE(NVL(B.L_ASCENSO, 0), 1, 'X', '') ASCENSO,
       DECODE(NVL(B.L_UBICACION, 0), 1, 'X', '') UBICACION,
       DECODE(NVL(B.L_TRASLADO, 0), 1, 'X', '') TRASLADO,
       DECODE(NVL(B.L_VACACION, 0), 1, 'X', '') VACACION,
       DECODE(NVL(B.L_SUBROGACION, 0), 1, 'X', '') SUBROGACION,
       DECODE(NVL(B.L_ENCARGO, 0), 1, 'X', '') ENCARGO,
       DECODE(NVL(B.L_COMISION, 0), 1, 'X', '') COMISION,
       DECODE(NVL(B.L_REVALORACION, 0), 1, 'X', '') REVALORACION,
       DECODE(NVL(B.L_RECLASIFICACION, 0), 1, 'X', '') RECLASIFICACION,
       DECODE(NVL(B.L_RENUNCIA, 0), 1, 'X', '') RENUNCIA,
       DECODE(NVL(B.L_SUPRESION, 0), 1, 'X', '') SUPRESION,
       DECODE(NVL(B.L_DESTITUCION, 0), 1, 'X', '') DESTITUCION,
       DECODE(NVL(B.L_JUBILACION, 0), 1, 'X', '') JUBILACION,
       DECODE(NVL(B.L_NOMBRAMIENTO, 0), 1, 'X', '') NOMBRAMIENTO,
       DECODE(NVL(B.L_TRASPASO, 0), 1, 'X', '') TRASPASO,
       DECODE(NVL(B.L_CAMBIO, 0), 1, 'X', '') CAMBIO,
       DECODE(NVL(B.L_INTERCAMBIO, 0), 1, 'X', '') INTERCAMBIO,
       DECODE(NVL(B.L_LICENCIA, 0), 1, 'X', '') LICENCIA,
       DECODE(NVL(B.L_REINTEGRO, 0), 1, 'X', '') REINTEGRO,
       DECODE(NVL(B.L_RESTITUCION, 0), 1, 'X', '') RESTITUCION,
       DECODE(NVL(B.L_REMOCION, 0), 1, 'X', '') REMOCION,
       B.OTRO,
       B.PROCESO_INSTITU_ACTUAL,
       B.NIVEL_GESTION_ACTUAL,
       B.LUGAR_ACTUAL,
       B.PARTIDA_ACTUAL,
       B.REMUNERACION_ACTUAL,
       B.PUESTO_ACTUAL,
       B.PROCESOS_INSTITU_PROPUESTO,
       B.NIVEL_GESTION_PROPUESTO,
       B.PUESTO_PROPUESTO,
       B.LUGAR_PROPUESTO,
       B.REMUNERACION_PROPUESTO,
       B.PARTIDA_PROPUESTO,
       B.NO_ACTA_FINAL,
       B.FECHA_ACTA,
       B.FECHA_RIGE_H,
       B.NO_RRHH,
       B.DENOMINACION_PUESTO,
       B.DENOMINACION_PUESTO_PROPUESTO,
       B.GRUPO_OCUPACIONAL,
       B.GRUPO_OCUPACIONAL_PROPUESTO,
       B.GRADO_ACTUAL,
       B.GRADO_PROPUESTO,
       P.DESCRIP CARGO
  FROM RH.T_ACCION_PERSONAL2025 B,
       RH.T_DAT_EMPLEADO    A,
       RH.T_DAT_EMPLEADO    C,       
       RH.T_DAT_EMPLEADO    E,
       RH.T_DAT_EMPLEADO    F,
       RH.T_CONTRATACIONES X,
       RH.T_FUNCION         P
 WHERE A.NO_PERSONA(+) = B.NO_PERSONA
   AND C.NO_PERSONA(+) = B.NO_JEFE_PERSONA
   AND E.NO_PERSONA(+) = B.NO_DIRECTOR   
   AND B.NO_JEFE_PERSONA = X.NO_PERSONA
   AND X.NO_FUNCION = P.NO_FUNCION
   AND F.NO_PERSONA(+) = B.NO_PERSONA_REEMPLAZA
   AND B.NO_ACCION = $P{ACCION}]]>
	</queryString>
