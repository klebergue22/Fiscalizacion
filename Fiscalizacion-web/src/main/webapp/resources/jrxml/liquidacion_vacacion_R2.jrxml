<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="liquidacion_vacacion_v2" pageWidth="595" pageHeight="842" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="80458285-7a11-4536-854f-e29d47b8af78">
	<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="PERMISOS"/>
	<parameter name="CODIGO2" class="java.lang.String"/>
	<parameter name="FECHAINICIO2" class="java.lang.String"/>
	<parameter name="FECHAFINAL2" class="java.lang.String"/>
	<queryString language="SQL">
		<![CDATA[SELECT     nvl(trunc(sum(PERMISOS.FPER_TIEMPO_EFECTIVO_PERMISOOK (A.F_INICO , A.F_FINALIZACION, D.NO_PERSONA ))/8),0) DIAS,
                     nvl(trunc(((sum(PERMISOS.FPER_TIEMPO_EFECTIVO_PERMISOOK (A.F_INICO , A.F_FINALIZACION, D.NO_PERSONA ))/8)-trunc(sum(PERMISOS.FPER_TIEMPO_EFECTIVO_PERMISOOK (A.F_INICO , A.F_FINALIZACION, D.NO_PERSONA ))/8))*8),0) HORAS,
NVL(sum(PERMISOS.FPER_TIEMPO_EFECTIVO_PERMISOOK (A.F_INICO , A.F_FINALIZACION, D.NO_PERSONA ))/8,0) TOTAL_REAL
FROM     RH.T_ASISTENCIAS A, RH.T_DAT_EMPLEADO D, RH.T_RH_TIPO_ASISTENCIA T
WHERE     A.NO_ASIST IN (3,14) AND 
    ((A.NO_ASIST = T.NO_ASIST) AND 
    (A.NO_PERSONA =D.NO_PERSONA)) AND 
    TO_NUMBER(D.CODIGO) = TO_NUMBER($P{CODIGO2})  AND 
    TRUNC(A.F_INICO) >= TO_DATE($P{FECHAINICIO2}, 'DD/MM/YYYY')  AND
    TRUNC(A.F_FINALIZACION)<= TO_DATE($P{FECHAFINAL2},  'DD/MM/YYYY')]]>
	</queryString>
	<field name="DIAS" class="java.math.BigDecimal">
		<property name="com.jaspersoft.studio.field.name" value="DIAS"/>
		<property name="com.jaspersoft.studio.field.label" value="DIAS"/>
	</field>
	<field name="HORAS" class="java.math.BigDecimal">
		<property name="com.jaspersoft.studio.field.name" value="HORAS"/>
		<property name="com.jaspersoft.studio.field.label" value="HORAS"/>
	</field>
	<field name="TOTAL_REAL" class="java.math.BigDecimal">
		<property name="com.jaspersoft.studio.field.name" value="TOTAL_REAL"/>
		<property name="com.jaspersoft.studio.field.label" value="TOTAL_REAL"/>
	</field>
