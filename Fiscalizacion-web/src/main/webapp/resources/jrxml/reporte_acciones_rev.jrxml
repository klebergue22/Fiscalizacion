	<queryString language="SQL">
		<![CDATA[SELECT     
    A.NOMBRE_C,
    A.NO_CEDULA CEDULA_POSESIONADO,
    B.NO_CAUCION, 
    B.FECHA_CAUCION, 
    B.OBS_CAUCION, 
    B.PUESTO_REEMPLAZA, 
    B.OBS_REEMPLAZA, 
    B.NO_ACCION_REEMPLAZA, 
    B.FECHA_ACCION_REEMPLAZA, 
    B.COLEGIO_PROFESIONALES, 
    B.NO_AFILIACION_COLEGIO, 
    B.FECHA_AFILIACION, 
    B.LUGAR_POSESION, 
    B.FECHA_POSESION,
    C.NOMBRE_C RESPONSABLE_ELABORACION,
    D.NOMBRE_C RESPONSABLE_REVISION,              
    E.NOMBRE_C RESPONSABLE_NOTIFICACION,
    F.NOMBRE_C RESPONSABLE_REGISTROYCONTROL,    
    P.DESCRIP CARGO_ELABORA,
    Q.DESCRIP CARGO_REVISA,
    R.DESCRIP CARGO_NOTIFICA,
    S.DESCRIP CARGO_REYCO
FROM     RH.T_ACCION_PERSONAL2025 B, 
    RH.T_DAT_EMPLEADO A,     
    RH.T_DAT_EMPLEADO C,       
    RH.T_DAT_EMPLEADO D,
    RH.T_DAT_EMPLEADO E,
    RH.T_DAT_EMPLEADO F,    
    RH.T_CONTRATACIONES X,
    RH.T_CONTRATACIONES Y,
    RH.T_CONTRATACIONES V,
    RH.T_CONTRATACIONES W,        
    RH.T_FUNCION         P,
    RH.T_FUNCION         Q,
    RH.T_FUNCION         R,
    RH.T_FUNCION         S    
WHERE A.NO_PERSONA (+) = B.NO_PERSONA     
    AND C.NO_PERSONA (+) = B.NO_PERSONA_ELABORACION
    AND D.NO_PERSONA (+) = B.NO_PERSONA_REVI
    AND E.NO_PERSONA (+) = B.NO_PERSONA_NOTI
    AND F.NO_PERSONA (+) = B.NO_PERSONA_REYCO
    AND X.NO_PERSONA (+) = B.NO_PERSONA_ELABORACION
    AND Y.NO_PERSONA (+) = B.NO_PERSONA_REVI
    AND V.NO_PERSONA (+) = B.NO_PERSONA_NOTI
    AND W.NO_PERSONA (+) = B.NO_PERSONA_REYCO
    AND X.NO_FUNCION = P.NO_FUNCION  AND X.F_SALIDA IS NULL
    AND Y.NO_FUNCION = Q.NO_FUNCION  AND Y.F_SALIDA IS NULL
    AND V.NO_FUNCION = R.NO_FUNCION  AND V.F_SALIDA IS NULL
    AND W.NO_FUNCION = S.NO_FUNCION  AND W.F_SALIDA IS NULL
    AND B.NO_ACCION = $P{ACCION}]]>
	</queryString>
