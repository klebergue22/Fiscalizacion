<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="reporte_ocho_horas_semanal" pageWidth="595" pageHeight="842" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="c6bfcf43-4b9f-4e49-a4df-3bc762f4af59">
	<parameter name="pathImagen" class="java.lang.String"/>
	<parameter name="FechaDesde" class="java.lang.String"/>
	<queryString language="SQL">
		<![CDATA[SELECT q.no_persona,
       q.codigo,
       q.nombre_c,
       q.horas_semana
  FROM (
        SELECT e.no_persona,
               TO_NUMBER(e.codigo) AS codigo,
               e.nombre_c,
               ROUND(SUM(d.horas_dia), 2) AS horas_semana
          FROM t_dat_empleado e
          JOIN t_contrataciones c ON c.no_persona = e.no_persona
          JOIN (
                SELECT r.codigo,
                       TRUNC(r.fecha) AS fecha_dia,
                       GREATEST((MAX(r.fecha) - MIN(r.fecha)) * 24, 0) AS horas_dia
                  FROM reloj r
                 WHERE TRUNC(r.fecha, 'IW') = TRUNC(TO_DATE($P{FechaDesde}, 'DD/MM/YYYY'), 'IW')
                 GROUP BY r.codigo, TRUNC(r.fecha)
               ) d ON d.codigo = TO_NUMBER(e.codigo)
         WHERE c.estado = 'V'
           AND c.c_contrato IN (28, 32)
         GROUP BY e.no_persona, TO_NUMBER(e.codigo), e.nombre_c
       ) q
 WHERE q.horas_semana < 8
 ORDER BY q.codigo]]>
	</queryString>
	<field name="NO_PERSONA" class="java.math.BigDecimal"/>
	<field name="CODIGO" class="java.math.BigDecimal"/>
	<field name="NOMBRE_C" class="java.lang.String"/>
	<field name="HORAS_SEMANA" class="java.math.BigDecimal"/>
