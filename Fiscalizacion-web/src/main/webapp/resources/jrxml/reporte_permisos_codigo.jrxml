	</field>
	<field name="MINU" class="java.math.BigDecimal">
		<property name="com.jaspersoft.studio.field.label" value="MINU"/>
	</field>
	<field name="OBS" class="java.lang.String">
		<property name="com.jaspersoft.studio.field.label" value="OBS"/>
	</field>
	<variable name="tDias" class="java.math.BigDecimal" resetType="Group" resetGroup="estado" calculation="Sum">
		<variableExpression><![CDATA[$F{DIAS}]]></variableExpression>
	</variable>
	<variable name="tHoras" class="java.math.BigDecimal" resetType="Group" resetGroup="estado" calculation="Sum">
		<variableExpression><![CDATA[$F{HORAS}]]></variableExpression>
	</variable>
	<variable name="tMin" class="java.math.BigDecimal" resetType="Group" resetGroup="estado" calculation="Sum">
		<variableExpression><![CDATA[$F{MINU}]]></variableExpression>
	</variable>
	<variable name="totales" class="java.math.BigDecimal" resetType="Group" resetGroup="estado">
		<variableExpression><![CDATA[$V{tHoras}.add($V{tMin}.divide(new BigDecimal(60),2,2))]]></variableExpression>
	</variable>
	<variable name="totalDias" class="java.math.BigDecimal" resetType="Group" resetGroup="estado">
		<variableExpression><![CDATA[$V{tDias}.add($V{totales}.divide(new BigDecimal(8),2,2))]]></variableExpression>
	</variable>
