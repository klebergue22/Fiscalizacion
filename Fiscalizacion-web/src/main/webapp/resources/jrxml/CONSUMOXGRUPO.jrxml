<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="CONSUMOXGRUPO" pageWidth="595" pageHeight="842" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="5484f1ae-b746-43a8-aab7-5742a51ced0a">
	<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="IGM1_RH"/>
	<parameter name="PERIODO_CODIGO" class="java.lang.String"/>
	<parameter name="FECHA_DESDE" class="java.lang.String"/>
	<parameter name="FECHA_HASTA" class="java.lang.String"/>
	<parameter name="GRUPO" class="java.lang.String"/>
	<parameter name="pathImagen" class="java.lang.String"/>
	<queryString language="SQL">
		<![CDATA[SELECT   G.DESC_GRUPO,  A.NO_ARTICULO, 
    NO_UND_MED, 
    E.DESCRIP ARTICULO,
    E.COSTO_COMERCIAL,
    E.VALOR_UNIT_ULT_COMPRA ULT_COMPRA,
    SUM(ABS(A.CANTIDAD)) CANTIDAD, 
    SUM(ABS(A.CANTIDAD) * A.UNITARIO) TOTAL
  FROM     INVENTARIOS.T_DET_MOV A,
           INVENTARIOS.T_MOV B,
           INVENTARIOS.T_DET_PEDIDO C,
           INVENTARIOS.T_PEDIDO D,
           INVENTARIOS.T_ARTICULO E,
           INVENTARIOS.T_AREAS F,
           INVENTARIOS.T_TIPO_MOV_INV T,
           INVENTARIOS.T_GRUPOS_ARTICULOS G
 WHERE     A.PERIODO_CODIGO = B.PERIODO_CODIGO AND 
    A.NO_MOV = B.NO_MOV AND 
    T.NO_TIP_MOV_INV = B.NO_TIPO_MOV AND
    E.GRUPO=G.GRUPO AND
    D.NO_CD = F.NO_CD AND 
    A.NO_PEDIDO = C.NO_PEDIDO AND 
    A.PERIODO_CODIGO = C.PERIODO_CODIGO AND 
    A.NO_REG_PEDIDO = C.NO_REG_PEDIDO AND 
    A.NO_ARTICULO = C.NO_ARTICULO AND 
    C.NO_PEDIDO = D.NO_PEDIDO AND 
    C.PERIODO_CODIGO = D.PERIODO_CODIGO AND 
    E.NO_ARTICULO = C.NO_ARTICULO AND 
    A.PERIODO_CODIGO =  $P{PERIODO_CODIGO} AND 
   (T.NO_TIP_MOV_INV = 9 OR T.NO_TIP_MOV_INV = 10 ) AND  
    E.GRUPO =  $P{GRUPO} 
    AND B.FECHA BETWEEN  $P{FECHA_DESDE}  AND  $P{FECHA_HASTA} AND 
    A.CANTIDAD<0
GROUP BY G.DESC_GRUPO, A.NO_ARTICULO,E.DESCRIP,
    NO_UND_MED,
    E.COSTO_COMERCIAL,
    E.VALOR_UNIT_ULT_COMPRA
ORDER BY E.DESCRIP]]>
	</queryString>
