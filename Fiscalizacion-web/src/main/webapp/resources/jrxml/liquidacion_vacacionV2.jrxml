	<parameter name="FechaDesde" class="java.lang.String"/>
	<parameter name="FechaHasta" class="java.lang.String"/>
	<queryString language="SQL">
		<![CDATA[SELECT * FROM V_PERMISOS_EMPLEADO
WHERE TO_NUMBER(CODIGO)=TO_NUMBER($P{CODIGO})
AND DESCRIP IN ('PERSONAL','VACACION ADELANTADA') 
AND  (TRUNC (F_INICO) BETWEEN  TO_DATE($P{FechaDesde}, 'DD/MM/YYYY') 
AND TO_DATE($P{FechaHasta}, 'DD/MM/YYYY'))
ORDER BY DESCRIP,F_INICO]]>
	</queryString>
